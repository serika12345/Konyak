{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Konyak Flutter (Linux)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/konyak",
      "program": "lib/main.dart",
      "deviceId": "linux",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=KONYAK_REPO_ROOT=${workspaceFolder}",
        "--dart-define=KONYAK_DART_EXECUTABLE=dart",
        "--dart-define=KONYAK_CLI_SCRIPT=${workspaceFolder}/packages/konyak_cli/bin/konyak.dart",
        "--dart-define=KONYAK_RUNTIME_PROFILE=development",
        "--dart-define=KONYAK_LINUX_WINE_HOME=${workspaceFolder}/.dart_tool/konyak/dev-runtime/linux-wine"
      ],
      "env": {
        "KONYAK_REPO_ROOT": "${workspaceFolder}",
        "KONYAK_DART_EXECUTABLE": "dart",
        "KONYAK_CLI_SCRIPT": "${workspaceFolder}/packages/konyak_cli/bin/konyak.dart",
        "KONYAK_RUNTIME_PROFILE": "development",
        "KONYAK_LINUX_WINE_HOME": "${workspaceFolder}/.dart_tool/konyak/dev-runtime/linux-wine"
      }
    },
    {
      "name": "Konyak Flutter (macOS)",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/konyak",
      "program": "lib/main.dart",
      "deviceId": "macos",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define=KONYAK_REPO_ROOT=${workspaceFolder}",
        "--dart-define=KONYAK_DART_EXECUTABLE=${workspaceFolder}/.dart_tool/konyak/flutter-sdk/bin/dart",
        "--dart-define=KONYAK_CLI_SCRIPT=${workspaceFolder}/packages/konyak_cli/bin/konyak.dart",
        "--dart-define=KONYAK_RUNTIME_PROFILE=development",
        "--dart-define=KONYAK_MACOS_WINE_HOME=${workspaceFolder}/.dart_tool/konyak/dev-runtime/macos-wine",
        "--dart-define=KONYAK_DEV_MACOS_WINE_STACK_MANIFEST=${workspaceFolder}/.dart_tool/konyak/dev-runtime-source/macos-wine-stack/konyak-macos-wine-runtime-stack-source.json",
        "--dart-define=KONYAK_MACOS_DEV_RUNTIME_PREPARE_SCRIPT=${workspaceFolder}/scripts/prepare_macos_dev_runtime_stack.zsh"
      ],
      "preLaunchTask": "Konyak: Prepare Flutter SDK macOS",
      "env": {
        "FLUTTER_ROOT": "${workspaceFolder}/.dart_tool/konyak/flutter-sdk",
        "KONYAK_REPO_ROOT": "${workspaceFolder}",
        "KONYAK_DART_EXECUTABLE": "${workspaceFolder}/.dart_tool/konyak/flutter-sdk/bin/dart",
        "KONYAK_CLI_SCRIPT": "${workspaceFolder}/packages/konyak_cli/bin/konyak.dart",
        "KONYAK_RUNTIME_PROFILE": "development",
        "KONYAK_MACOS_WINE_HOME": "${workspaceFolder}/.dart_tool/konyak/dev-runtime/macos-wine",
        "KONYAK_DEV_MACOS_WINE_STACK_MANIFEST": "${workspaceFolder}/.dart_tool/konyak/dev-runtime-source/macos-wine-stack/konyak-macos-wine-runtime-stack-source.json",
        "KONYAK_MACOS_DEV_RUNTIME_PREPARE_SCRIPT": "${workspaceFolder}/scripts/prepare_macos_dev_runtime_stack.zsh",
        "DEVELOPER_DIR": "/Applications/Xcode.app/Contents/Developer",
        "PATH": "${workspaceFolder}/.dart_tool/konyak/vscode-bin:/usr/bin:/bin:/usr/sbin:/sbin:${workspaceFolder}/.dart_tool/konyak/flutter-sdk/bin:${env:PATH}"
      }
    }
  ]
}
