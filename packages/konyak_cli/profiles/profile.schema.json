{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/serika12345/Konyak/main/packages/konyak_cli/profiles/profile.schema.json",
  "title": "Konyak compatibility profile",
  "description": "Declarative compatibility rules for a Windows program in Konyak.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "id",
    "name",
    "profileVersion",
    "summary",
    "platforms",
    "windowsVersion",
    "managedProgramPath",
    "installerResource",
    "dependencyWinetricksVerbs",
    "runCompletionPolicy",
    "compatibilityProfile"
  ],
  "properties": {
    "$schema": {
      "const": "https://raw.githubusercontent.com/serika12345/Konyak/main/packages/konyak_cli/profiles/profile.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "profileVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 999999
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "description": "Hosts the profile is intended for. Profile platform enforcement is not implemented yet; childProcessRules is currently effective on macOS only.",
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["macos", "linux"]
      }
    },
    "windowsVersion": {
      "enum": ["winxp64", "win7", "win8", "win81", "win10", "win11"]
    },
    "managedProgramPath": {
      "type": "string",
      "minLength": 8,
      "pattern": "^[Cc]:[\\\\/](?:(?!\\.{1,2}(?:[\\\\/]|$))[^\\u0000\\\\/]+[\\\\/])*(?!\\.{1,2}$)[^\\u0000\\\\/]+\\.[Ee][Xx][Ee]$"
    },
    "installerResource": {
      "description": "Immutable HTTPS source for the Windows installer executed by profile installation.",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "url", "sha256", "fileName"],
      "properties": {
        "kind": {
          "const": "https"
        },
        "url": {
          "type": "string",
          "minLength": 9,
          "maxLength": 8192,
          "pattern": "^https://[^/?#@\\u0000-\\u0020\\u007f]+(?:[/?][^#\\u0000-\\u0020\\u007f]*)?$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9A-Fa-f]{64}$"
        },
        "fileName": {
          "description": "A basename ending in .exe or .msi; path separators and control characters are forbidden.",
          "type": "string",
          "minLength": 5,
          "maxLength": 255,
          "pattern": "^[^/\\\\\\u0000-\\u001f\\u007f]+\\.(?:[Ee][Xx][Ee]|[Mm][Ss][Ii])$"
        }
      }
    },
    "dependencyWinetricksVerbs": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9_.+-]+$"
      }
    },
    "runCompletionPolicy": {
      "enum": ["waitForExit", "launchOnly"]
    },
    "compatibilityProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "profileVersion", "childProcessRules"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9_.-]*$"
        },
        "profileVersion": {
          "type": "integer",
          "minimum": 1,
          "maximum": 999999
        },
        "childProcessRules": {
          "description": "Rules for appending missing arguments to matching Windows child processes. Implemented by the Konyak macOS Wine runtime only in schema version 1; Linux does not yet propagate or apply these rules.",
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["executableSuffix", "appendArgumentsIfMissing"],
            "properties": {
              "executableSuffix": {
                "description": "Printable ASCII suffix matched case-insensitively against the child executable path.",
                "type": "string",
                "minLength": 1,
                "maxLength": 1024,
                "pattern": "^[\\u0020-\\u007e]+$"
              },
              "appendArgumentsIfMissing": {
                "type": "array",
                "minItems": 1,
                "maxItems": 64,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 8192,
                  "pattern": "^[^\\u0000\\u0009\\u000a\\u000d\\u0020\\u0022]+$"
                }
              }
            }
          }
        }
      }
    }
  }
}
